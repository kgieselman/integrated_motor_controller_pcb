	(text "1.6K with a VRef of 3.3V gives a cut off around 4.53A"
		(exclude_from_sim no)
		(at 181.61 102.108 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "155ba6f3-f7ff-42dc-9849-51a914ea0618")
	)
	(text "The PMODE pin state is latched when the device is enabled through the nSLEEP\npin. The PMODE state can be changed by taking the nSLEEP pin logic low, waiting the tSLEEP time, changing the\nPMODE pin input, and then enabling the device by taking the nSLEEP pin back logic high"
		(exclude_from_sim no)
		(at 62.23 115.824 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "c8713ba9-3c1f-4b43-9c77-8bf000c724cd")
	)
	(text "TI recommends 22uF minimum for VM capactiors.\nAfter derating, 3 are needed.\nThe caps chose are basic parts at JLC.\nThis could be consolidated using better capacitors."
		(exclude_from_sim no)
		(at 55.626 46.99 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "cf070495-287c-42bf-98f1-2f737df685b7")
	)
	(text_box "R(IMODE)\nQuad-Level 1 | GND  | Auto-retry, overcurrent fault\nQuad-Level 2 | 20k  | Auto-retry, overcurrent fault, current chop fault\nQuad-Level 3 | 62k  | Latch, overcurrent fault, current chop fault\nQuad-Level 4 | Hi-Z | Latch, overcurrent fault"
		(exclude_from_sim no)
		(at 22.86 91.44 0)
